# =============================================================================
# Language of Freedom — copy to .env.local and fill in values
# =============================================================================

# Supabase (Settings → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# New publishable key (recommended)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_
# Legacy anon JWT (optional if using publishable key above)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=
# Service role key (Settings → API Keys → secret). Required for Stripe webhooks.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — keys must be from the SAME account and SAME mode (both test or both live).
# NEXT_PUBLIC_* is baked in at build time: after changing it in Vercel, redeploy.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Site URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Branding fallbacks
NEXT_PUBLIC_BOOK_SHORT_TITLE=Language of Freedom
NEXT_PUBLIC_SITE_NAME=Language of Freedom

# Resend (optional locally)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Language of Freedom
ADMIN_EMAIL=
